# ============================================================
# AI Document Assistant (Backend) — Environment Variables Template
# ------------------------------------------------------------
# 1. Copy this file and rename the copy to ".env"
# 2. Fill in your real values below
# 3. NEVER commit your actual ".env" file to GitHub
# ============================================================

# --- OpenAI API Key ---
# Required if LLM_PROVIDER=ollama (the default).
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- LLM Provider Selection ---
# Options: "openai" (default) | "ollama" | "huggingface"
LLM_PROVIDER=ollama

# --- OpenAI Model Settings ---
OLLAMA_MODEL_NAME=llama3.2
LLM_TEMPERATURE=0.2

# --- Embedding Model (runs locally, no key required) ---
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- Text Chunking Settings ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval Settings ---
RETRIEVAL_TOP_K=4

# --- CORS Settings (NEW) ---
# Comma-separated list of frontend origins allowed to call this API.
# Local development default (Vite's default dev server port):
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# In production, replace with your deployed frontend URL, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app